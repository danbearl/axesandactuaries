# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real keys.

# ── Database ──────────────────────────────────────────────────────────────────
# Matches the docker-compose postgres service (local dev default)
DATABASE_URL="postgresql://adventurer:adventurer@localhost:5432/adventurer_manager"

# ── Redis ─────────────────────────────────────────────────────────────────────
# Local docker-compose redis (Phase 4 will wire this up properly)
REDIS_URL="redis://localhost:6379"

# ── Clerk ─────────────────────────────────────────────────────────────────────
# Get these from https://dashboard.clerk.com → your app → API Keys
CLERK_SECRET_KEY="sk_test_..."
CLERK_PUBLISHABLE_KEY="pk_test_..."

# ── Sentry ────────────────────────────────────────────────────────────────────
# Get from sentry.io → your project → Settings → Client Keys (DSN)
# Leave blank in local dev to disable Sentry reporting
SENTRY_DSN=

# ── API server ────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Shared secret for POST /api/v1/announcements/webhook — the deploy workflow
# (.github/workflows/deploy.yml) uses this to post a draft deploy-summary announcement.
# Generate with `openssl rand -hex 32`; set the same value here and as the
# ANNOUNCEMENTS_WEBHOOK_SECRET GitHub Actions repo secret and the Fly app secret.
ANNOUNCEMENTS_WEBHOOK_SECRET=

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# Vite only exposes env vars prefixed with VITE_
VITE_CLERK_PUBLISHABLE_KEY="pk_test_..."
VITE_API_URL="http://localhost:3001"
# Same Sentry project as SENTRY_DSN above, or a separate frontend project — your call.
# Leave blank in local dev to disable Sentry reporting.
VITE_SENTRY_DSN=
