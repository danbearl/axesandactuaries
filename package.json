{
  "name": "axes-actuaries",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev:frontend": "pnpm --filter @axes-actuaries/frontend dev",
    "dev:api": "pnpm --filter @axes-actuaries/api dev",
    "dev": "pnpm --filter @axes-actuaries/frontend dev",
    "build": "pnpm --filter types build && pnpm --filter frontend build && pnpm --filter api build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r --if-present test",
    "db:migrate": "pnpm --filter @axes-actuaries/api db:migrate",
    "db:generate": "pnpm --filter @axes-actuaries/api db:generate",
    "db:studio": "pnpm --filter @axes-actuaries/api db:studio",
    "db:test:create": "pnpm --filter @axes-actuaries/api db:test:create",
    "db:test:migrate": "pnpm --filter @axes-actuaries/api db:test:migrate",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "db:seed": "pnpm --filter @axes-actuaries/api db:seed",
    "roadmap:board": "node scripts/generate-roadmap-board.mjs"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  }
}
