{
  "name": "adventurer-manager",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev:frontend": "pnpm --filter @adventurer-manager/frontend dev",
    "dev:api": "pnpm --filter @adventurer-manager/api dev",
    "dev": "pnpm --filter @adventurer-manager/frontend dev",
    "build": "pnpm --filter types build && pnpm --filter frontend build && pnpm --filter api build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r --if-present test",
    "db:migrate": "pnpm --filter @adventurer-manager/api db:migrate",
    "db:generate": "pnpm --filter @adventurer-manager/api db:generate",
    "db:studio": "pnpm --filter @adventurer-manager/api db:studio",
    "db:test:create": "pnpm --filter @adventurer-manager/api db:test:create",
    "db:test:migrate": "pnpm --filter @adventurer-manager/api db:test:migrate",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "db:seed": "pnpm --filter @adventurer-manager/api db:seed"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
