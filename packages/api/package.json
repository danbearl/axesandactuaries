{
  "name": "@adventurer-manager/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:test:create": "docker compose exec -T postgres psql -U adventurer -d adventurer_manager -c \"CREATE DATABASE adventurer_manager_test\" 2>/dev/null || true",
    "db:test:migrate": "DATABASE_URL=\"${TEST_DATABASE_URL:-postgresql://adventurer:adventurer@localhost:5432/adventurer_manager_test}\" prisma migrate deploy",
    "test": "DATABASE_URL=\"${TEST_DATABASE_URL:-postgresql://adventurer:adventurer@localhost:5432/adventurer_manager_test}\" vitest run",
    "test:watch": "DATABASE_URL=\"${TEST_DATABASE_URL:-postgresql://adventurer:adventurer@localhost:5432/adventurer_manager_test}\" vitest"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@adventurer-manager/types": "workspace:*",
    "@clerk/express": "^1.3.0",
    "@prisma/client": "^6.1.0",
    "@sentry/node": "^10.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "express-rate-limit": "^7.0.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.11.1",
    "pg-boss": "^12.20.0",
    "prisma": "^6.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0"
  }
}
