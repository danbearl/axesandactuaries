generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ─────────────────────────────────────────────────────────────────────

enum AdventurerStatus {
  available
  hired
  on_adventure
  injured
  dead
}

enum ContractStatus {
  available
  bidding
  awarded
  in_progress
  completed
  failed
  expired
}

enum ContractTier {
  errand
  standard
  dangerous
  legendary
}

enum AdventureStatus {
  in_progress
  completed
  failed
}

enum PropertyType {
  dormitory
  training_hall
  alchemy_lab
  library
  infirmary
  armory
}

enum TransactionReason {
  contract_payment
  wage
  hire_cost
  property_build
  property_sell
  property_maintenance
  penalty
  debt_forgiven
  starting_gold
  admin_adjustment
  contract_abandoned
}

// ── Models ────────────────────────────────────────────────────────────────────

model Player {
  id            String    @id @default(cuid())
  clerkUserId   String    @unique @map("clerk_user_id")
  username      String    @unique
  guildName     String?   @map("guild_name")
  isAdmin       Boolean   @default(false) @map("is_admin")
  gold          Int       @default(500)
  reputation    Int       @default(0)
  lastWelfareAt DateTime? @map("last_welfare_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  adventurers  Adventurer[]
  adventures   Adventure[]
  properties   Property[]
  transactions Transaction[]
  contractBids ContractBid[]

  @@map("players")
}

model Adventurer {
  id                  String           @id @default(cuid())
  name                String
  heritage            String
  vocation            String
  gender              String
  level               Int              @default(1)
  experience          Int              @default(0)
  powerRating         Int              @map("power_rating")
  stats               Json
  personality         Json
  hireCost            Int              @map("hire_cost")
  dailyWage           Int              @map("daily_wage")
  status              AdventurerStatus @default(available)
  injuryRecoveryUntil DateTime?        @map("injury_recovery_until")
  restUntil           DateTime?        @map("rest_until")
  employerId          String?          @map("employer_id")
  poolExpiresAt       DateTime?        @map("pool_expires_at")
  wagesOwed           Int              @default(0) @map("wages_owed")
  daysUnpaid          Int              @default(0) @map("days_unpaid")
  loyaltyPenalty      Int              @default(0) @map("loyalty_penalty")
  // Consecutive days at 'hired' status without being deployed — feeds the ambition-driven
  // idle loyalty decay (see services/economy.ts). Reset to 0 the instant they're deployed
  // (startAdventure); does not accrue while on_adventure, injured, or resting.
  daysIdle            Int              @default(0) @map("days_idle")
  height              String
  build               String
  complexion          String
  hairColor           String           @map("hair_color")
  eyeColor            String           @map("eye_color")
  createdAt           DateTime         @default(now()) @map("created_at")

  employer    Player?               @relation(fields: [employerId], references: [id])
  adventures  AdventureAdventurer[]
  cohesionAsLow  AdventurerCohesion[] @relation("CohesionLow")
  cohesionAsHigh AdventurerCohesion[] @relation("CohesionHigh")

  @@index([status, employerId])
  @@map("adventurers")
}

model Contract {
  id                String         @id @default(cuid())
  title             String
  description       String
  tier              ContractTier
  requiredPower     Int            @map("required_power")
  requiredStats     Json           @map("required_stats")
  requiredVocation  String?        @map("required_vocation")
  rewardGold        Int            @map("reward_gold")
  reputationReward  Int            @map("reputation_reward")
  penaltyGold       Int            @map("penalty_gold")
  penaltyReputation Int            @map("penalty_reputation")
  durationHours     Int            @map("duration_hours")
  status            ContractStatus @default(available)
  awardedTo         String?        @map("awarded_to")
  // Null until a contract's first bid lands, at which point it's set to give everyone a
  // fair, full window to counter-bid (see BID_WINDOW_HOURS) — a bidding-tier contract with
  // no bids yet has no deadline at all, so it never disappears from the market just from
  // time passing. Direct-accept tiers (errand/standard) never use this field.
  bidDeadline       DateTime?      @map("bid_deadline")
  expiresAt         DateTime       @map("expires_at")
  // Deadline to deploy a party once awarded — set the instant a contract transitions to
  // 'awarded' (direct accept, bid win, or welfare claim). Missing it counts as a failed
  // contract (same penaltyGold/penaltyReputation as an actually-failed adventure), so an
  // awarded-but-abandoned contract can't sit unclaimed forever. Null until awarded.
  deployBy          DateTime?      @map("deploy_by")
  createdAt         DateTime       @default(now()) @map("created_at")

  adventures Adventure[]
  bids       ContractBid[]

  @@index([status, bidDeadline])
  @@index([status, deployBy])
  @@map("contracts")
}

model ContractBid {
  id         String   @id @default(cuid())
  contractId String   @map("contract_id")
  playerId   String   @map("player_id")
  createdAt  DateTime @default(now()) @map("created_at")

  contract Contract @relation(fields: [contractId], references: [id])
  player   Player   @relation(fields: [playerId], references: [id])

  @@unique([contractId, playerId])
  @@map("contract_bids")
}

model Adventure {
  id          String          @id @default(cuid())
  contractId  String          @map("contract_id")
  playerId    String          @map("player_id")
  startsAt    DateTime        @map("starts_at")
  completesAt DateTime        @map("completes_at")
  status      AdventureStatus @default(in_progress)
  outcomeRoll Float?          @map("outcome_roll")
  resolvedAt  DateTime?       @map("resolved_at")
  createdAt   DateTime        @default(now()) @map("created_at")

  contract    Contract              @relation(fields: [contractId], references: [id])
  player      Player                @relation(fields: [playerId], references: [id])
  adventurers AdventureAdventurer[]

  @@index([completesAt, status])
  @@map("adventures")
}

model AdventureAdventurer {
  adventureId  String @map("adventure_id")
  adventurerId String @map("adventurer_id")

  // Per-adventurer outcome, recorded at resolution. Snapshotting these here (rather than
  // relying on the Adventurer's current state) is what makes contract completion reports
  // possible — the Adventurer row only ever reflects its *current* status, which a later
  // adventure or recovery can overwrite.
  xpGained      Int      @default(0) @map("xp_gained")
  injured       Boolean  @default(false)
  died          Boolean  @default(false)
  recoveryHours Int?     @map("recovery_hours")

  adventure  Adventure  @relation(fields: [adventureId], references: [id])
  adventurer Adventurer @relation(fields: [adventurerId], references: [id])

  @@id([adventureId, adventurerId])
  @@map("adventure_adventurers")
}

// Party cohesion between two adventurers, built up by completing contracts together
// (see COHESION_* in @axes-actuaries/types). One row per unordered pair — no row means
// the pair has never adventured together. To avoid ambiguity about direction, every
// read/write sorts the pair's two IDs first and always stores the lexicographically lower
// one as adventurerLowId; there is deliberately no query helper that accepts an unordered
// pair; callers must sort before touching this table.
model AdventurerCohesion {
  adventurerLowId  String @map("adventurer_low_id")
  adventurerHighId String @map("adventurer_high_id")
  cohesion         Int    @default(0)

  adventurerLow  Adventurer @relation("CohesionLow", fields: [adventurerLowId], references: [id])
  adventurerHigh Adventurer @relation("CohesionHigh", fields: [adventurerHighId], references: [id])

  @@id([adventurerLowId, adventurerHighId])
  @@index([adventurerHighId])
  @@map("adventurer_cohesion")
}

model Property {
  id                   String       @id @default(cuid())
  playerId             String       @map("player_id")
  type                 PropertyType
  level                Int          @default(1)
  maintenanceCostDaily Int          @map("maintenance_cost_daily")
  bonus                Json
  costBasis            Int          @default(0) @map("cost_basis")
  createdAt            DateTime     @default(now()) @map("created_at")

  player Player @relation(fields: [playerId], references: [id])

  @@map("properties")
}

model Transaction {
  id          String            @id @default(cuid())
  playerId    String            @map("player_id")
  amount      Int
  reason      TransactionReason
  description String
  referenceId String?           @map("reference_id")
  createdAt   DateTime          @default(now()) @map("created_at")

  player Player @relation(fields: [playerId], references: [id])

  @@map("transactions")
}

// Freeform wiki/documentation content. No in-app editor yet — edited directly
// via `pnpm db:studio` until Admin/Moderator roles exist to gate one safely.
model WikiPage {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  body      String
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("wiki_pages")
}
